<?xml version="1.0" encoding="utf-8"?>
<!--
    FlareClientActivity root layout.
    Stack order (bottom to top):
      1. fl_container  — DivKit rendered screens live here
      2. transition_overlay — navigation loading animation + error card
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- DivKit screen container -->
    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Transition overlay — overlaid on top; GONE by default -->
    <com.example.flare_android_client.TransitionOverlayView
        android:id="@+id/transition_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>