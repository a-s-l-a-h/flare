{
  "card": {
    "log_id": "welcome_screen",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "container",
          "orientation": "vertical",
          "height": { "type": "match_parent" },
          "background": [{ "type": "solid", "color": "#f0f2f8" }],
          "paddings": { "top": 80, "bottom": 48, "left": 20, "right": 20 },
          "items": [
            {
              "type": "container",
              "orientation": "vertical",
              "background": [{ "type": "solid", "color": "#ffffff" }],
              "border": { "corner_radius": 20 },
              "paddings": { "top": 32, "bottom": 32, "left": 20, "right": 20 },
              "margins": { "bottom": 24 },
              "items": [
                {
                  "type": "text",
                  "text": "Hello, @{flare_first_name} 👋",
                  "font_size": 24,
                  "font_weight": "bold",
                  "text_alignment_horizontal": "center",
                  "text_color": "#1a1a2e"
                }
              ]
            },
            {
              "type": "text",
              "text": "📝 My Notes",
              "font_size": 18,
              "font_weight": "bold",
              "text_alignment_horizontal": "center",
              "text_color": "#ffffff",
              "background": [{ "type": "solid", "color": "#8e44ad" }],
              "border": { "corner_radius": 16 },
              "paddings": { "top": 20, "bottom": 20 },
              "margins": { "bottom": 16 },
              "alpha": "@{local_flare_pending_go_to_notes ? 0.5 : 1.0}",
              "action": {
                "log_id": "btn_notes",
                "url": "flare://action",
                "payload": { "flare_action": "go_to_notes" }
              }
            },
            {
              "type": "container",
              "orientation": "vertical",
              "visibility": "@{flare_is_admin ? 'visible' : 'gone'}",
              "items": [
                {
                  "type": "text",
                  "text": "👑 Admin Dashboard",
                  "font_size": 18,
                  "font_weight": "bold",
                  "text_alignment_horizontal": "center",
                  "text_color": "#ffffff",
                  "background": [{ "type": "solid", "color": "#1a1a2e" }],
                  "border": { "corner_radius": 16 },
                  "paddings": { "top": 20, "bottom": 20 },
                  "margins": { "bottom": 16 },
                  "alpha": "@{local_flare_pending_go_to_admin ? 0.5 : 1.0}",
                  "action": {
                    "log_id": "btn_admin",
                    "url": "flare://action",
                    "payload": { "flare_action": "go_to_admin" }
                  }
                }
              ]
            },
            {
              "type": "text",
              "text": "Edit Profile",
              "font_size": 16,
              "font_weight": "bold",
              "text_alignment_horizontal": "center",
              "text_color": "#1a1a2e",
              "paddings": { "top": 16, "bottom": 16 },
              "alpha": "@{local_flare_pending_go_to_profile ? 0.5 : 1.0}",
              "action": {
                "log_id": "btn_profile",
                "url": "flare://action",
                "payload": { "flare_action": "go_to_profile" }
              }
            }
          ]
        }
      }
    ]
  }
}