                        {
                          "type": "container",
                          "orientation": "vertical",
                          "width": {
                            "type": "fixed",
                            "value": 80
                          },
                          "height": {
                            "type": "fixed",
                            "value": 80
                          },
                          "background": [
                            {
                              "type": "solid",
                              "color": "#ffffff33"
                            }
                          ],
                          "border": {
                            "corner_radius": 40
                          },
                          "content_alignment_horizontal": "center",
                          "content_alignment_vertical": "center",
                          "margins": {
                            "bottom": 16
                          },
                          "items": [
                            {
                              "type": "text",
                              "text": "👤",
                              "font_size": 36,
                              "text_alignment_horizontal": "center"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "text": "@{flare_first_name == '' ? 'No name set yet' : flare_first_name + ' ' + flare_last_name}",
                          "font_size": 20,
                          "font_weight": "bold",
                          "text_alignment_horizontal": "center",
                          "text_color": "#ffffff"
                        }
                      ]
                    },
                    {
                      "type": "container",
                      "orientation": "vertical",
                      "background": [
                        {
                          "type": "solid",
                          "color": "@{flare_dark_mode ? '#1c1c2e' : '#ffffff'}"
                        }
                      ],
                      "border": {
                        "corner_radius": 24
                      },
