                  "content_alignment_vertical": "center",
                  "items": [
                    {
                      "type": "container",
                      "orientation": "vertical",
                      "width": {
                        "type": "fixed",
                        "value": 40
                      },
                      "height": {
                        "type": "fixed",
                        "value": 40
                      },
                      "background": [
                        {
                          "type": "solid",
                          "color": "@{flare_dark_mode ? '#1c1c2e' : '#ffffff'}"
                        }
                      ],
                      "border": {
                        "corner_radius": 20
                      },
                      "content_alignment_horizontal": "center",
                      "content_alignment_vertical": "center",
                      "items": [
                        {
                          "type": "text",
                          "text": "←",
                          "font_size": 15,
                          "font_weight": "bold",
                          "text_alignment_horizontal": "center",
                          "text_color": "@{flare_dark_mode ? '#9090a8' : '#888888'}",
                          "alpha": "@{local_flare_pending_go_back ? 0.35 : 1.0}",
                          "action": {
                            "log_id": "btn_back",
                            "url": "flare://action",
                            "payload": {
                              "flare_action": "go_back"
                            }
                          },
                          "width": {
                            "type": "fixed",
                            "value": 34
                          }
                        }
                      ]
                      
                    },
                    {
                      "type": "text",
                      "text": "👤 Profile",
                      "font_size": 20,
                      "font_weight": "bold",
                      "text_color": "@{flare_dark_mode ? '#f0f0f5' : '#1a1a2e'}",
                      "width": {
                        "type": "match_parent"
                      },
                      "weight": 1,
                      "text_alignment_horizontal": "center"
                    },
                    {
                      "type": "container",
                      "orientation": "vertical",
                      "width": {
                        "type": "fixed",
                        "value": 40
                      },
                      "height": {
                        "type": "fixed",
                        "value": 40
                      },
                      "background": [
                        {
                          "type": "solid",
                          "color": "@{flare_dark_mode ? '#1c1c2e' : '#ffffff'}"
                        }
                      ],
                      "border": {
                        "corner_radius": 20
                      },
                      "content_alignment_horizontal": "center",
                      "content_alignment_vertical": "center",
                      "margins": {
                        "right": 10
                      },
                      "items": [
                        {
                          "type": "text",
                          "text": "@{flare_dark_mode ? '☀️' : '🌙'}",
                          "font_size": 18,
                          "text_alignment_horizontal": "center"
                        }
                      ],
                      "action": {
                        "log_id": "btn_theme",
                        "url": "flare://action",
                        "payload": {
                          "flare_action": "toggle_theme"
                        }
                      }
                    },
                    {
                      "type": "container",
                      "orientation": "vertical",
                      "width": {
                        "type": "fixed",
                        "value": 40
                      },
                      "height": {
                        "type": "fixed",
                        "value": 40
                      },
                      "background": [
                        {
                          "type": "solid",
                          "color": "@{flare_dark_mode ? '#1c1c2e' : '#ffffff'}"
