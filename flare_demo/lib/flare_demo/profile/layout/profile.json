{
  "card": {
    "log_id": "div2_sample_card",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "gallery",
          "orientation": "vertical",
          "width": {
            "type": "match_parent"
          },
          "height": {
            "type": "match_parent"
          },
          "background": [
            {
              "type": "solid",
              "color": "@{flare_dark_mode ? '#0f0f1a' : '#f0f2f8'}"
            }
          ],
          "items": [
            {
              "type": "container",
              "orientation": "vertical",
              "width": {
                "type": "match_parent"
              },
              "height": {
                "type": "wrap_content"
              },
              "items": [
                {
                  "type": "container",
                  "orientation": "horizontal",
                  "paddings": {
                    "top": 56,
                    "bottom": 16,
                    "left": 20,
                    "right": 20
