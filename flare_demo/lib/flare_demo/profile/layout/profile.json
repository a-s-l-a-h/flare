                        "left": 20,
                        "right": 20
                      },
                      "margins": {
                        "bottom": 16
                      },
                      "items": [
                        {
                          "type": "text",
                          "text": "FIRST NAME",
                          "font_size": 11,
                          "font_weight": "bold",
                          "text_color": "@{flare_dark_mode ? '#7070888' : '#aaaaaa'}",
                          "letter_spacing": 2,
                          "margins": {
                            "bottom": 8
                          }
                        },
                        {
                          "type": "input",
                          "text_variable": "local_first_name",
