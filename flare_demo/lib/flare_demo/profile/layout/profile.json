                          "font_size": 16,
                          "text_color": "@{flare_dark_mode ? '#f0f0f5' : '#1a1a2e'}",
                          "hint_color": "@{flare_dark_mode ? '#5a5a70' : '#cccccc'}",
                          "highlight_color": "#8e44ad",
                          "accessibility": {
                            "description": "First name input"
                          },
                          "background": [
                            {
                              "type": "solid",
                              "color": "@{flare_dark_mode ? '#2a2a3e' : '#f7f7f7'}"
                            }
                          ],
                          "border": {
                            "corner_radius": 12
                          },
                          "paddings": {
                            "top": 14,
                            "bottom": 14,
                            "left": 16,
                            "right": 16
                          },
                          "margins": {
                            "bottom": 20
                          }
                        },
                        {
                          "type": "text",
                          "text": "LAST NAME",
                          "font_size": 11,
                          "font_weight": "bold",
                          "text_color": "@{flare_dark_mode ? '#707088' : '#aaaaaa'}",
                          "letter_spacing": 2,
                          "margins": {
                            "bottom": 8
                          }
                        },
                        {
                          "type": "input",
                          "text_variable": "local_last_name",
                          "hint_text": "Enter last name (optional)",
                          "font_size": 16,
                          "text_color": "@{flare_dark_mode ? '#f0f0f5' : '#1a1a2e'}",
                          "hint_color": "@{flare_dark_mode ? '#5a5a70' : '#cccccc'}",
                          "highlight_color": "#8e44ad",
                          "accessibility": {
                            "description": "Last name input"
                          },
                          "background": [
                            {
                              "type": "solid",
                              "color": "@{flare_dark_mode ? '#2a2a3e' : '#f7f7f7'}"
                            }
                          ],
                          "border": {
                            "corner_radius": 12
                          },
                          "paddings": {
                            "top": 14,
                            "bottom": 14,
                            "left": 16,
                            "right": 16
                          },
                          "margins": {
                            "bottom": 28
                          }
                        },
                        {
                          "type": "text",
                          "text": "@{local_flare_pending_save_profile ? 'Saving...' : 'Save Profile'}",
                          "font_size": 16,
                          "font_weight": "bold",
                          "text_alignment_horizontal": "center",
                          "text_color": "#ffffff",
                          "background": [
                            {
                              "type": "solid",
                              "color": "#8e44ad"
                            }
                          ],
                          "border": {
                            "corner_radius": 14
                          },
                          "paddings": {
                            "top": 16,
                            "bottom": 16
                          },
                          "alpha": "@{local_flare_pending_save_profile ? 0.35 : 1.0}",
                          "action": {
                            "log_id": "btn_save",
                            "url": "flare://action",
                            "payload": {
                              "flare_action": "save_profile",
                              "first_name": "@{local_first_name}",
                              "last_name": "@{local_last_name}"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ],
              "margins": {
                "left": 0,
                "top": 0
              }
            }
          ]
        }
      }
    ]
  },
  "templates": {}
}