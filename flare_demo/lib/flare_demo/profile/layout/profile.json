                      "items": [
                        {
                          "type": "text",
                          "text": "🚪",
                          "font_size": 16,
                          "text_alignment_horizontal": "center"
                        }
                      ],
                      "action": {
                        "log_id": "btn_logout",
                        "url": "flare://action",
                        "payload": {
                          "flare_action": "logout"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "container",
                  "orientation": "vertical",
                  "paddings": {
                    "bottom": 48,
                    "left": 20,
                    "right": 20
